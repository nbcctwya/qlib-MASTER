    "Sharpe": "sqrt(252)*mean(g)/std(g,ddof=1)",
    "Sortino": "sqrt(252)*mean(g)/sqrt(mean(min(g,0)^2))",
    "Calmar": "AR/abs(MDD)",
    "ICIR_annualized": false
  },
